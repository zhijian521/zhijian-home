root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 160

[*.{js,mjs,cjs,ts,tsx,jsx,json,jsonc,css}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[specs/**]
# 规范文档不强制列宽/缩进
max_line_length = off
